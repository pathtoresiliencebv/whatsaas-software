PORT=8080
LOG_LEVEL=info

# Public URL of the deployed Next.js SaaS app.
VOICE_API_BASE_URL=https://app.example.com
VOICE_RUNTIME_SECRET=generate-a-secure-random-string

# LiveKit Cloud project used by browser calls and SIP-routed calls.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PIPECAT_AGENT_NAME=kyrn-pipecat

# Default realtime model providers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# Needed only for direct Twilio Media Streams fallback.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
