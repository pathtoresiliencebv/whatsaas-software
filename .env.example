POSTGRES_URL=postgres://postgres:postgres@localhost:54322/postgres

# OAuth (optional - enables "Continue with Google/GitHub" buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
# ^^^ REPLACE WITH LIVE KEYS FOR PRODUCTION:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Note: Use 'sk_live_' for production, 'sk_test_' for development

BASE_URL=http://localhost:3000
AUTH_SECRET=***

# Allowed origins for CORS (comma-separated for multiple)
ALLOWED_ORIGIN=https://yourdomain.com

PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=

EVOLUTION_API_URL=

NEXT_PUBLIC_WEBHOOK_URL=
EVOLUTION_WEBHOOK_TOKEN=
NEXT_PUBLIC_EVOLUTION_WEBHOOK_TOKEN=
NEXT_PUBLIC_EVOLUTION_WEBHOOK_URL=

AUTHENTICATION_API_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.com
SUPPORT_EMAIL=

VOICE_CALL_CREDIT_PRICE_CENTS=500
VOICE_CALL_CREDITS_PER_PACK=100

# Realtime voice runtime (Pipecat + LiveKit + Twilio)
API_ONLY_DEPLOYMENT=false
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PIPECAT_AGENT_NAME=kyrn-pipecat
PIPECAT_WEBSOCKET_BASE_URL=
VOICE_RUNTIME_SECRET=generate-a-secure-random-string

# Cron secret for campaign processing
CRON_SECRET=generate-a-secure-random-string

# Campaign send delay in ms (default: 200 = 5 msg/sec max)
# WhatsApp rate limit: ~60 msg/min per phone
CAMPAIGN_DELAY_MS=200

# Meta WhatsApp Business API (for Meta Cloud provider)
META_APP_ID=
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
NEXT_PUBLIC_FACEBOOK_API_VERSION=v21.0

# Composio
COMPOSIO_API_KEY=
COMPOSIO_AUTH_CONFIG_ID=
