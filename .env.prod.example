# WhatSaaS Production Environment Variables
# Copy to .env.prod and fill in real values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ─── Database ────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-to-a-strong-password

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-64-char-random-string

# ─── Domain ──────────────────────────────────────────────────────────────────
BASE_URL=https://yourdomain.com
ALLOWED_ORIGIN=https://yourdomain.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Evolution API ────────────────────────────────────────────────────────────
EVOLUTION_API_URL=https://evolution.yourdomain.com
AUTHENTICATION_API_KEY=your-evolution-api-key
EVOLUTION_WEBHOOK_TOKEN=your-webhook-token

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=change-me

# ─── Pusher (Realtime) ───────────────────────────────────────────────────────
PUSHER_APP_ID=your-pusher-app-id
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret
NEXT_PUBLIC_PUSHER_CLUSTER=us2
